<!Doctype html>
<html>

<head>
    <title> ANIMATION </title>
    <style>
        .container {
            background-color: rgb(190, 189, 189);
            border: 5px solid purple;
            height: 500px;
            width: 100%;
        }

        header {
            background-color: brown;
            color: rgb(231, 132, 11);
            width: 150px;
            text-align: center;
            margin-left: 700px;
        }

        .linder1 {
            background-color: blueviolet;
            border: 1px solid rgb(17, 16, 16);
            height: 80px;
            width: 90%;
        }

        .linder2 {
            background-color: white;
            border: 5px solid yellow;
            height: 20px;
            width: 60%;
            margin-top: 20px;

        }

        .loader {
            background-color: rgb(169, 169, 180);
            width: 100%;
            height: 20px;
        }

        .loader_inner {
            height: 20px;
            background-color: blue;
            animation: slide 2s linear infinite;
        }

        @keyframes slide {
            0% {
                transform: translate(0%);
            }

            55% {
                margin-left: 60%;
            }

            100% {
                transform: translate(70%);
            }
        }

        .move_holder {
            background-image: url(2.png);
            background-repeat: repeat;
            height: 150px;
            width: 100%;
            display: flex;
        }

        .move1,
        .move2,
        .move3 {
            width: 100px;
            height: 90px;
            background-color: rgb(51, 49, 49);
            animation: go 5s linear infinite;
            border-radius: 50%;
        }

        @keyframes go {
            0% {
                margin-left: 0%;
            }

            70% {
                margin-left: 65%;
            }

            100% {
                margin-left: 100%;
            }
        }

        .move1 {
            background-color: blue;
            text-align: center;
            box-shadow: 4px 5px 4px purple;
        }

        .move2 {
            background-color: rgb(0, 170, 71);
            text-align: center;
            box-shadow: 4px 5px 4px red;
        }

        .move3 {
            background-color: rgb(255, 3, 3);
            text-align: center;
            box-shadow: 4px 5px 4px rgb(7, 214, 7);
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="loader">
            <div class="loader_inner"></div>
        </div>

        <div class="move_holder">
            <div class="move1">USA</div>
            <div class="move2"> NIGERIA</div>
            <div class="move3">CANADA</div>

        </div>
        <div class="index_holder">
            <h2> Best-Computer-training-school-Abuja-Bizmarrow-Technologies-Nigeria </h2>
            <div class="google">  </div>
            <div class="AWS"> cloud _ server_ most protected  </div>
            <div> </div>
            <div> </div>
            <div> </div>
        </div>
    </div>
</body>
